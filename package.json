{
  "name": "sandbox0",
  "version": "0.1.12",
  "description": "Sandbox0 JavaScript/TypeScript SDK",
  "license": "Apache-2.0",
  "author": "Sandbox0 Team",
  "keywords": [
    "sandbox",
    "sdk",
    "sandbox0"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc -p tsconfig.build.json && node ./scripts/fix-esm-imports.mjs",
    "build:eve": "npm run build && npm --prefix packages/eve run build",
    "lint": "tsc -p tsconfig.json --noEmit",
    "lint:eve": "npm run build && npm --prefix packages/eve run lint",
    "lint:e2e": "tsc -p tsconfig.e2e.json --noEmit",
    "lint:unit": "tsc -p tsconfig.unit.json --noEmit",
    "generate:apispec": "openapi-generator-cli generate -i openapi.yaml -g typescript-fetch -o src/apispec -c openapi-generator-config.yaml",
    "test": "npm run test:unit",
    "test:e2e": "npm run test:e2e:sdk && npm run test:e2e:frameworks",
    "test:e2e:frameworks": "npm run test:e2e:eve",
    "test:e2e:sdk": "node --import tsx --test tests/e2e/sdk/*.test.ts",
    "test:e2e:eve": "npm run build:eve && npm --prefix packages/eve run test:e2e",
    "test:unit": "node --import tsx --test tests/unit/**/*.test.ts",
    "test:eve": "npm --prefix packages/eve run test"
  },
  "devDependencies": {
    "@openapitools/openapi-generator-cli": "^2.28.3",
    "@types/node": "^25.2.3",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "undici": "^8.5.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sandbox0-ai/sdk-js"
  },
  "dependencies": {
    "shlex": "^3.0.0",
    "ws": "^8.19.0"
  }
}
